VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_OR_ANON_KEY

# Public contact channel URLs used by the floating chat dock.
# Replace with the production official account URLs before launch.
VITE_CONTACT_WHATSAPP_URL=https://wa.me/YOUR_OFFICIAL_WHATSAPP_NUMBER
VITE_CONTACT_LINE_URL=https://line.me/R/ti/p/YOUR_OFFICIAL_LINE_ID
VITE_CONTACT_WECHAT_URL=weixin://dl/chat?YOUR_OFFICIAL_WECHAT_ID
VITE_CONTACT_KAKAO_URL=https://pf.kakao.com/YOUR_OFFICIAL_KAKAO_ID/chat

# Server-only Vercel API variables. Never expose these in client code.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
ADMIN_API_TOKEN=CHANGE_ME_TO_A_LONG_RANDOM_INTERNAL_TOKEN
PARTNER_API_TOKEN=CHANGE_ME_TO_A_LONG_RANDOM_PARTNER_TOKEN
PROVIDER_API_TOKEN=CHANGE_ME_TO_A_LONG_RANDOM_PROVIDER_TOKEN

# Optional scoped token maps for account-specific partner/provider portals.
# Format: {"token_value":"uuid-account-id"}
PARTNER_TOKEN_MAP={}
PROVIDER_TOKEN_MAP={}
